# Gecko Integration - Development Overrides
# Copy this file to .env (in the same directory) to override auth/tenant settings.
# .env is gitignored and will NOT be committed.

# Auth0 tenant base URL (no trailing slash)
GECKO_AUTH0_URL_BASE=https://gecko-stage.us.auth0.com

# OAuth2 Client ID for your Auth0 application
GECKO_OAUTH2_CLIENT_ID=8L8YjbL1KL2K7hqg08isis32Q28dHfGW

# API base URL (no trailing slash)
GECKO_API_BASE_URL=https://dev.api.geckowatermonitor.com
